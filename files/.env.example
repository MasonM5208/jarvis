# ─────────────────────────────────────────────────────────────────────────────
#  JARVIS — Environment Configuration
#  Copy this file to .env and fill in real values.
#  .env is gitignored — never commit real keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Platform ──────────────────────────────────────────────────────────────────
JARVIS_PLATFORM=mac          # mac | pi | pc

# ── API Keys ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...  # Required for dynamic plugin writer (Phase 0)
OPENAI_API_KEY=               # Optional — fallback / Open WebUI

# ── Ollama (Mac / PC) ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── llama.cpp server (Pi) ─────────────────────────────────────────────────────
PI_LLM_BASE_URL=http://localhost:8080
PI_LLM_MODEL=llama3.2-1b-hef

# ── API Server ────────────────────────────────────────────────────────────────
JARVIS_HOST=0.0.0.0
JARVIS_PORT=8000

# ── Memory ────────────────────────────────────────────────────────────────────
TOP_K_RESULTS=5
MEMORY_CHUNK_SIZE=512
MEMORY_OVERLAP=64

# ── Agent ─────────────────────────────────────────────────────────────────────
MAX_ITERATIONS=10
TEMPERATURE=0.7
CONTEXT_WINDOW=4096

# ── Knowledge Sources ─────────────────────────────────────────────────────────
OBSIDIAN_VAULT_PATH=~/Documents/Obsidian
CLASS_NOTES_PATH=~/Documents/Classes

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_TO_FILE=true
